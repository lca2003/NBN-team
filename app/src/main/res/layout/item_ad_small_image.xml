<?xml version="1.0" encoding="utf-8"?>
<!-- 小图卡（参考图风格）：左文右小图，紧凑干净。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_feed_card"
    android:clickable="true"
    android:elevation="2dp"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- 上半部分：左文右图 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 左侧文字区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/nbn_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="周末本地咖啡地图" />

            <TextView
                android:id="@+id/summaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/nbn_text_secondary"
                android:textSize="13sp"
                tools:text="发现附近适合学习和小组讨论的咖啡空间。" />

            <TextView
                android:id="@+id/brandText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/nbn_text_secondary"
                android:textSize="12sp"
                tools:text="City Cafe" />
        </LinearLayout>

        <!-- 右侧小图 -->
        <ImageView
            android:id="@+id/mediaImage"
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_media_placeholder"
            android:contentDescription="@string/feed_sponsored"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <!-- 标签容器 -->
    <LinearLayout
        android:id="@+id/tagGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal" />

    <!-- 统计 -->
    <TextView
        android:id="@+id/statsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/nbn_text_secondary"
        android:textSize="11sp"
        tools:text="曝光 1 · 点击 0" />

    <!-- 互动栏 -->
    <include layout="@layout/view_interaction_bar" />
</LinearLayout>
