<?xml version="1.0" encoding="utf-8"?>
<!-- 列表底部 footer（升级版）：带顶部分割线、品牌色进度条、更精致的文案样式。
     由 FeedAdapter 作为最后一个 item 渲染，配合上拉加载使用。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/footerRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="20dp">

    <!-- 顶部分割线 -->
    <View
        android:layout_width="60dp"
        android:layout_height="1dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@color/nbn_divider" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="40dp">

        <!-- 加载中：品牌色进度条 + 文案 -->
        <LinearLayout
            android:id="@+id/footerLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:indeterminateTint="@color/nbn_brand"
                style="?android:attr/progressBarStyleSmall" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/feed_loading_more"
                android:textColor="@color/nbn_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 文案态：没有更多 / 点击重试 -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="8dp"
            android:textColor="@color/nbn_text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            android:text="@string/feed_no_more" />
    </FrameLayout>
</LinearLayout>
