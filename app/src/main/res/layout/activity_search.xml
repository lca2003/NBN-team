<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nbn_surface"
    android:orientation="vertical"
    android:fitsSystemWindows="true">
    
    
    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/searchCloseButton"
            android:layout_width="72dp"
            android:layout_height="40dp"
            android:text="@string/search_close"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/search_title"
            android:textColor="@color/nbn_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="72dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <!-- 对话界面 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchConversationList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp" />

    <!-- 输入栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/nbn_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/search_input_hint"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/nbn_text_primary"
            android:textColorHint="@color/nbn_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/searchSendButton"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="@string/search_send"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
