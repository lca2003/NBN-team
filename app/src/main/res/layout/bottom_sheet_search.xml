<?xml version="1.0" encoding="utf-8"?>
<!-- 主页面对话式搜索弹出半透明布局，主要取自原来activity_search.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/searchBottomSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_search_sheet"
    android:clipToOutline="true"
    android:elevation="8dp"
    android:orientation="vertical">
    
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_search_title_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <Button
            android:id="@+id/searchCloseButton"
            android:layout_width="56dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_search_close_button"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/search_close"
            android:textColor="@color/nbn_text_secondary"
            android:textSize="14sp"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/search_title"
            android:textColor="@color/nbn_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="56dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D8E6DC" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchConversationList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp" />

    <LinearLayout
        android:id="@+id/searchInputBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/bg_search_input_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_input"
            android:hint="@string/search_input_hint"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/nbn_text_primary"
            android:textColorHint="@color/nbn_text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/searchSendButton"
            android:layout_width="64dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_search_send_button"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/search_send"
            android:textColor="@color/nbn_card"
            android:textSize="15sp"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
